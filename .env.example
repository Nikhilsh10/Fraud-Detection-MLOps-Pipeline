# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.

# Kaggle API credentials (required for src/data/download.py)
# Get these from: https://www.kaggle.com/settings → API → Create New Token
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# MLflow tracking (local SQLite — no external service needed for Phase 1)
MLFLOW_TRACKING_URI=sqlite:///mlruns.db

# GitHub personal access token (needed in Phase 4 for repository_dispatch)
# GH_PAT=your_github_pat
